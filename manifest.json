{
  "manifest_version": 3,
  "name": "Multi-Language Selection Translator",
  "version": "0.0.1",
  "description": "Translate selected text into multiple languages on any page.",
  "action": { "default_popup": "src/popup/index.html" },
  "background": { "service_worker": "src/background/index.ts", "type": "module" },
  "content_scripts": [{ "matches": ["<all_urls>"], "js": ["src/content_script/index.ts"] }],
  "permissions": ["storage", "activeTab", "scripting"],
  "host_permissions": ["https://*/*"]
}
